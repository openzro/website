---
const title = "openZro — Open-source zero-trust mesh networking on WireGuard";
const description =
  "openZro is a self-hosted, BSD-3-Clause zero-trust mesh networking platform built on WireGuard. A community-maintained continuation of NetBird at v0.52.2, kept permissively licensed.";
---

<!doctype html>
<html lang="en" class="bg-ink text-white antialiased scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://openzro.io" />
    <meta property="og:image" content="https://openzro.io/brand/openzro-icon.svg" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0f0a1f" />
    <link rel="icon" type="image/svg+xml" href="/brand/openzro-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans">
    <!-- ===================== NAV ===================== -->
    <header
      class="sticky top-0 z-50 border-b border-violet-900/40 bg-ink/80 backdrop-blur-md"
    >
      <div
        class="mx-auto max-w-6xl px-4 sm:px-6 py-4 flex items-center justify-between"
      >
        <a href="/" class="flex items-center gap-2.5">
          <img
            src="/brand/openzro-icon.svg"
            alt=""
            width="32"
            height="32"
            class="rounded"
          />
          <span class="font-semibold text-xl tracking-wordmark leading-none">
            open<span class="text-violet-400 font-bold">Z</span>ro
          </span>
        </a>
        <nav
          class="hidden md:flex items-center gap-7 text-sm text-violet-200/80"
        >
          <a href="#features" class="hover:text-white transition">Features</a>
          <a href="#install" class="hover:text-white transition">Install</a>
          <a href="#why" class="hover:text-white transition">Why fork</a>
          <a
            href="https://docs.openzro.io"
            class="hover:text-white transition">Docs</a
          >
          <a
            href="https://github.com/openzro/openzro"
            class="hover:text-white transition">GitHub →</a
          >
        </nav>
      </div>
    </header>

    <!-- ===================== HERO ===================== -->
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-violet-900/20 via-transparent to-transparent pointer-events-none"
      >
      </div>
      <div
        class="relative mx-auto max-w-6xl px-4 sm:px-6 py-24 md:py-32 text-center"
      >
        <p
          class="inline-flex items-center gap-2 text-xs font-mono tracking-wider uppercase text-violet-300 mb-6 border border-violet-800/50 px-3 py-1 rounded-full"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-violet-400 animate-pulse"
          ></span>
          v0.53.1-alpha · BSD-3-Clause
        </p>
        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight leading-[1.1] mb-6 max-w-3xl mx-auto"
        >
          Open-source zero-trust mesh networking
          <span class="text-violet-400">on WireGuard.</span>
        </h1>
        <p class="text-lg md:text-xl text-violet-200/80 max-w-2xl mx-auto mb-10">
          Self-hosted control plane. Peer-to-peer overlay. Native clients on
          every OS. A community-maintained continuation of NetBird at the last
          BSD-3-Clause release, kept permissively licensed.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="https://docs.openzro.io/get-started/install"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-violet-600 hover:bg-violet-700 transition font-semibold text-sm"
          >
            Get started
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M5 12h14M13 5l7 7-7 7"></path></svg
            >
          </a>
          <a
            href="https://github.com/openzro/openzro"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-violet-800/60 hover:border-violet-600 hover:bg-violet-900/20 transition font-semibold text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58V21.1c-3.34.72-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.1-.74.08-.73.08-.73 1.21.08 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.82.58A12 12 0 0 0 12 0z"
              ></path></svg
            >
            Star on GitHub
          </a>
        </div>
        <pre
          class="mt-12 mx-auto max-w-2xl text-left bg-ink-2/60 border border-violet-900/50 rounded-lg p-4 text-sm font-mono overflow-x-auto"><span
            class="text-violet-400 select-none">$</span> curl -fsSL <span
            class="text-violet-300">https://pkg.openzro.io/install.sh</span> | sh</pre>
      </div>
    </section>

    <!-- ===================== FEATURES ===================== -->
    <section id="features" class="border-t border-violet-900/40">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20 md:py-24">
        <h2
          class="text-3xl md:text-4xl font-semibold tracking-tight mb-3 text-center"
        >
          Everything you need. None of the lock-in.
        </h2>
        <p
          class="text-violet-200/70 text-center mb-14 max-w-2xl mx-auto"
        >
          openZro ships the entire control plane in a single Helm chart. Run
          it on your own cluster. Own the data path end to end.
        </p>
        <div class="grid md:grid-cols-3 gap-5">
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <div
              class="w-10 h-10 rounded-lg bg-violet-900/40 text-violet-300 flex items-center justify-center mb-4"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="12" cy="12" r="3"></circle><path
                  d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                ></path></svg
              >
            </div>
            <h3 class="font-semibold text-lg mb-2">Self-hosted by design</h3>
            <p class="text-violet-200/70 text-sm leading-relaxed">
              Management, signal, relay, dashboard, IdP — every component runs
              on your infrastructure. No managed cloud, no usage telemetry, no
              third-party dependencies on the data path.
            </p>
          </div>
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <div
              class="w-10 h-10 rounded-lg bg-violet-900/40 text-violet-300 flex items-center justify-center mb-4"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path><path d="m9 12 2 2 4-4"></path></svg
              >
            </div>
            <h3 class="font-semibold text-lg mb-2">Zero-trust by default</h3>
            <p class="text-violet-200/70 text-sm leading-relaxed">
              WireGuard data plane. SSO via OIDC (Keycloak, Okta, Entra,
              Google, Authentik, Zitadel). Per-peer admission, posture checks,
              ACL policies, audit log shipping — out of the box.
            </p>
          </div>
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <div
              class="w-10 h-10 rounded-lg bg-violet-900/40 text-violet-300 flex items-center justify-center mb-4"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><polyline points="16 18 22 12 16 6"></polyline><polyline
                  points="8 6 2 12 8 18"></polyline></svg
              >
            </div>
            <h3 class="font-semibold text-lg mb-2">Permissively licensed</h3>
            <p class="text-violet-200/70 text-sm leading-relaxed">
              BSD-3-Clause across the tree. Forked from NetBird at v0.52.2 —
              the last BSD release before upstream's AGPL-3.0 relicense — to
              keep the codebase usable by operators, packagers and contributors
              who can't adopt AGPL.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== INSTALL ===================== -->
    <section id="install" class="border-t border-violet-900/40 bg-ink-2/20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20 md:py-24">
        <h2
          class="text-3xl md:text-4xl font-semibold tracking-tight mb-3 text-center"
        >
          Install on your stack
        </h2>
        <p
          class="text-violet-200/70 text-center mb-14 max-w-2xl mx-auto"
        >
          Signed packages on every major distro, native installers for Windows
          and macOS, plus a Helm chart for Kubernetes.
        </p>
        <div class="grid md:grid-cols-2 gap-5">
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <h3 class="font-semibold mb-3 text-violet-300">
              Linux · Debian / Ubuntu
            </h3>
            <pre
              class="text-sm font-mono text-violet-200/90 overflow-x-auto"><code>curl -fsSL https://pkg.openzro.io/openzro-archive-key.asc \
  | sudo gpg --dearmor -o /usr/share/keyrings/openzro.gpg
echo "deb [signed-by=/usr/share/keyrings/openzro.gpg] \
  https://pkg.openzro.io/apt stable main" \
  | sudo tee /etc/apt/sources.list.d/openzro.list
sudo apt update && sudo apt install openzro</code></pre>
          </div>
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <h3 class="font-semibold mb-3 text-violet-300">
              Linux · Fedora / RHEL / openSUSE
            </h3>
            <pre
              class="text-sm font-mono text-violet-200/90 overflow-x-auto"><code>sudo tee /etc/yum.repos.d/openzro.repo &lt;&lt;EOF
[openzro]
name=openZro
baseurl=https://pkg.openzro.io/rpm/\$basearch
enabled=1
gpgcheck=1
gpgkey=https://pkg.openzro.io/openzro-archive-key.asc
EOF
sudo dnf install openzro</code></pre>
          </div>
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <h3 class="font-semibold mb-3 text-violet-300">
              Linux · Arch / CachyOS / Manjaro
            </h3>
            <pre
              class="text-sm font-mono text-violet-200/90 overflow-x-auto"><code>yay -S openzro-bin
# or via the signed pacman repo:
# https://docs.openzro.io/get-started/install/linux</code></pre>
          </div>
          <div
            class="rounded-xl border border-violet-900/50 bg-ink-2/40 p-6"
          >
            <h3 class="font-semibold mb-3 text-violet-300">
              Kubernetes · Helm
            </h3>
            <pre
              class="text-sm font-mono text-violet-200/90 overflow-x-auto"><code>helm repo add openzro https://openzro.github.io/helms
helm install openzro openzro/openzro \
  --create-namespace -n openzro \
  -f my-values.yaml</code></pre>
          </div>
        </div>
        <p class="text-center mt-10 text-sm text-violet-200/60">
          Windows MSI · macOS PKG · Homebrew tap · Docker images · all on the
          <a
            href="https://github.com/openzro/openzro/releases"
            class="text-violet-400 hover:text-violet-300 underline">releases page</a
          >.
        </p>
      </div>
    </section>

    <!-- ===================== WHY FORK ===================== -->
    <section id="why" class="border-t border-violet-900/40">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 py-20 md:py-24">
        <h2
          class="text-3xl md:text-4xl font-semibold tracking-tight mb-6 text-center"
        >
          Why we forked
        </h2>
        <div class="space-y-5 text-violet-200/85 text-base leading-relaxed">
          <p>
            <a
              href="https://github.com/netbirdio/netbird"
              class="text-violet-400 hover:text-violet-300 underline"
              >NetBird</a
            > shipped under BSD-3-Clause for years. v0.53.0 (June 2025) relicensed
            the project to AGPL-3.0. AGPL is a fine license for some use cases —
            but it forces every operator who modifies the code to publish their
            changes, and forbids embedding into BSD/MIT downstream projects.
          </p>
          <p>
            For organizations that depend on a permissively-licensed mesh
            networking stack (cloud platforms, hardware vendors, network
            operators, OEMs), v0.53.0+ became unusable overnight.
          </p>
          <p>
            <span class="font-semibold text-white">openZro</span> picks up the BSD-3 codebase at v0.52.2 — the last commit before
            the relicense — and continues development under the original
            license. Every feature, every security backport, every breaking
            change is triaged clean-room from public CVE / GHSA prose to keep
            the BSD-3 tree provably free of AGPL contamination.
          </p>
          <p class="text-sm text-violet-200/60 pt-2">
            See <a
              href="https://github.com/openzro/openzro/blob/main/docs/adr/0001-openzro-foundation.md"
              class="text-violet-400 hover:text-violet-300 underline"
              >ADR-0001 — openZro Foundation</a
            > for the formal license posture and security backport rules.
          </p>
        </div>
      </div>
    </section>

    <!-- ===================== FOOTER ===================== -->
    <footer class="border-t border-violet-900/40 bg-ink-2/30">
      <div
        class="mx-auto max-w-6xl px-4 sm:px-6 py-12 grid md:grid-cols-4 gap-8"
      >
        <div class="md:col-span-2">
          <a href="/" class="flex items-center gap-2.5 mb-3">
            <img
              src="/brand/openzro-icon.svg"
              alt=""
              width="28"
              height="28"
              class="rounded"
            />
            <span class="font-semibold text-lg tracking-wordmark leading-none">
              open<span class="text-violet-400 font-bold">Z</span>ro
            </span>
          </a>
          <p class="text-sm text-violet-200/60 max-w-md">
            Open-source zero-trust mesh networking on WireGuard. BSD-3-Clause.
          </p>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-violet-300 mb-3">
            Product
          </h4>
          <ul class="space-y-2 text-sm">
            <li><a href="https://docs.openzro.io" class="text-violet-200/70 hover:text-white">Docs</a></li>
            <li><a href="https://github.com/openzro/openzro/releases" class="text-violet-200/70 hover:text-white">Releases</a></li>
            <li><a href="https://pkg.openzro.io" class="text-violet-200/70 hover:text-white">Packages</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-violet-300 mb-3">
            Project
          </h4>
          <ul class="space-y-2 text-sm">
            <li><a href="https://github.com/openzro/openzro" class="text-violet-200/70 hover:text-white">GitHub</a></li>
            <li><a href="https://github.com/openzro/openzro/blob/main/docs/adr" class="text-violet-200/70 hover:text-white">ADRs</a></li>
            <li><a href="https://github.com/openzro/openzro/blob/main/LICENSE" class="text-violet-200/70 hover:text-white">License</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-violet-900/40">
        <div
          class="mx-auto max-w-6xl px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-violet-200/50"
        >
          <span>© 2026 openZro · BSD-3-Clause</span>
          <span class="font-mono">
            WireGuard® is a registered trademark of Jason A. Donenfeld
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>
