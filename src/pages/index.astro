---
// openZro landing page. Bold dark hero with animated WireGuard mesh
// canvas, alternating dark/light sections, gradient typography. The
// design is a port of the design-handoff bundle Claude Design produced
// — content adapted to match what openZro actually ships today
// (BSD-3-Clause, real install URLs, real ADR links, accurate features).
//
// Stack notes:
//   * Astro 5 + Tailwind 3 — Tailwind covers utility shortcuts (max-w,
//     grid layouts on the use-case section); section-level visual
//     primitives (terminal chrome, mesh halo, marquee) live in the
//     two CSS files imported below.
//   * Canvas mesh visualization is vanilla JS (no React / preact)
//     loaded from src/scripts/mesh-viz.js. Astro ships only the JS
//     it explicitly imports.
//   * Reveal-on-scroll respects prefers-reduced-motion via the
//     `.reveal` class CSS rule (transition is gated server-side
//     in the stylesheet).

import "../styles/landing.css";
import "../styles/sections.css";

const title = "openZro — Self-hosted zero-trust mesh on WireGuard";
const description =
  "Self-hosted WireGuard mesh with HA, OIDC SSO, peer admission gates, and audit-grade logs. BSD-3-Clause continuation of NetBird at v0.52.2 — kept permissively licensed.";
const canonical = "https://openzro.io";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://openzro.io/brand/openzro-icon.svg" />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#0f0a1f" />
    <link rel="icon" type="image/svg+xml" href="/brand/openzro-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ============================================================
         1. NAV — sticky, blurs on scroll
         ============================================================ -->
    <nav class="nav" id="nav">
      <div class="nav-inner">
        <a href="/" class="brand">
          <img src="/brand/openzro-icon.svg" width="28" height="28" alt="" />
          <span class="brand-wm">open<em>Z</em>ro</span>
        </a>
        <div class="nav-links">
          <a href="#how">How it works</a>
          <a href="#features">Features</a>
          <a href="#cli">CLI</a>
          <a href="#use-cases">Use cases</a>
          <a href="#compare">Compare</a>
        </div>
        <div class="nav-cta">
          <a href="https://docs.openzro.io" class="nav-link">Docs</a>
          <a href="https://github.com/openzro/openzro" class="btn violet"
            >Self-host →</a
          >
        </div>
      </div>
    </nav>

    <!-- ============================================================
         2. HERO — animated mesh canvas + floating chips + marquee
         ============================================================ -->
    <section class="section hero deep">
      <div class="bg-aurora"></div>
      <div class="bg-grid-dark"></div>
      <div class="hero-spotlights"></div>

      <div class="section-inner hero-inner">
        <div class="hero-copy">
          <div class="tag dark live">v0.53.1 · BSD-3 fork of NetBird</div>
          <h1 class="display reveal">
            Zero-trust mesh,<br />
            <span class="grad">on your iron.</span>
          </h1>
          <p class="lead on-dark reveal">
            Self-hosted WireGuard mesh with high availability, OIDC SSO,
            peer admission and audit logs. A community-maintained
            continuation of NetBird at the last BSD-3 release —
            permissively licensed, fork-friendly, no SaaS dependency.
          </p>
          <div class="hero-cta reveal">
            <a
              href="https://docs.openzro.io/get-started/install"
              class="btn primary"
            >
              <span>Install openZro</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                ><path
                  d="M5 3l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </a>
            <a
              href="https://github.com/openzro/openzro/blob/main/docs/adr"
              class="btn ghost"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                ><path
                  d="M2 4l5 5 5-5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
              <span>Read the architecture</span>
            </a>
          </div>
          <div class="hero-meta reveal">
            <div class="meta-item">
              <span class="meta-k">PROTOCOL</span>
              <span class="meta-v">WireGuard</span>
            </div>
            <div class="meta-item">
              <span class="meta-k">LICENSE</span>
              <span class="meta-v">BSD-3</span>
            </div>
            <div class="meta-item">
              <span class="meta-k">DEPLOY</span>
              <span class="meta-v">self-host</span>
            </div>
            <div class="meta-item">
              <span class="meta-k">ADMISSION</span>
              <span class="meta-v">HITL gate</span>
            </div>
          </div>
        </div>
        <div
          class="hero-viz reveal"
          role="img"
          aria-label="Animated mesh of peers connecting to a central gateway"
        >
          <div class="mesh-wrap">
            <canvas id="mesh-canvas" class="mesh-canvas"></canvas>
            <div class="mesh-floats">
              <div class="float-chip f1">
                <span class="dot ok"></span>
                <span class="k">peer</span>
                <span class="v">edge-sa</span>
                <span class="lat">12ms</span>
              </div>
              <div class="float-chip f2">
                <span class="dot ok"></span>
                <span class="k">posture</span>
                <span class="v">verified</span>
              </div>
              <div class="float-chip f3">
                <span class="dot warn"></span>
                <span class="k">admission</span>
                <span class="v">3 pending</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="marquee">
        <div class="marquee-track" id="marquee-track">
          <!-- items duplicated by JS for seamless loop -->
          <span class="marquee-item"
            ><span class="dot"></span>wg0 up · 12ms</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>peer admitted · sha256:e1c…</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>posture · macOS 14.4 · FileVault on</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>intune · device compliant ✓</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>sentinelone · agent healthy ✓</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>k8s-prod joined mesh</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>audit log · 1,284 events</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>HA failover · embedded NATS</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>OIDC · keycloak ok</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>route advertised · 10.42.0.0/16</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>setup-key · scope: prod</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>relay · rel://relay.example.com:33080</span
          >
          <span class="marquee-item"
            ><span class="dot"></span>helm install openzro openzro/openzro</span
          >
        </div>
      </div>
    </section>

    <!-- ============================================================
         3. HOW IT WORKS — light section, 3 cards with code
         ============================================================ -->
    <section class="section light" id="how">
      <div class="bg-grid-light"></div>
      <div class="section-inner">
        <header class="sec-head">
          <span class="eyebrow on-light"
            ><span class="dot"></span>How it works</span
          >
          <h2 class="display">
            Three steps from <em>nothing</em> to a working mesh.
          </h2>
        </header>
        <div class="steps">
          <div class="step reveal">
            <div class="step-num">01</div>
            <h3>Stand up the control plane</h3>
            <p>
              One Helm chart on Kubernetes or one Ansible playbook on bare
              metal. HA out of the box via embedded NATS coordinator — no
              external Redis required, no SaaS dependency, no phone-home.
            </p>
            <pre class="code-block light"><code>$ helm repo add openzro https://openzro.github.io/helms
$ helm install openzro openzro/openzro \
    --create-namespace -n openzro</code></pre>
          </div>
          <div class="step reveal">
            <div class="step-num">02</div>
            <h3>Join peers through your IdP</h3>
            <p>
              Embedded Dex federates Keycloak, Auth0, Google, Microsoft Entra,
              Okta, Authentik, GitHub. Setup keys for headless joiners
              (servers, CI runners). ACLs by tag — peer-to-peer mesh after
              admission.
            </p>
            <pre class="code-block light"><code>$ openzro up
→ awaiting OIDC login · browser opened
✓ joined · scope: prod · routes: 10.42.0.0/16</code></pre>
          </div>
          <div class="step reveal">
            <div class="step-num">03</div>
            <h3>Route, observe, scale</h3>
            <p>
              WireGuard tunnels stay peer-to-peer. Every admission, route
              change, and policy diff is logged. Add gateway hosts as you
              grow — the rolling-update playbook drains and re-adds via cloud
              LB without breaking peers.
            </p>
            <pre class="code-block light"><code>$ ansible-playbook -i inventories/prod \
    playbooks/update.yml \
    -e openzro_version=0.53.1-alpha.13</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         4. FEATURES — dark section, 6-card grid in a bordered panel
         ============================================================ -->
    <section class="section dark" id="features">
      <div class="bg-grid-dark"></div>
      <div class="section-inner">
        <header class="sec-head">
          <span class="eyebrow on-dark"
            ><span class="dot"></span>Features</span
          >
          <h2 class="display on-dark">
            Six capabilities that turn WireGuard<br />
            into an enterprise-grade fabric.
          </h2>
          <p class="lead on-dark">
            Permissive licensing, real HA, native installers on every OS, and
            a control plane you can drop into your existing observability.
          </p>
        </header>
        <div class="features-grid">
          <div class="feature reveal">
            <svg
              width="28"
              height="28"
              viewBox="0 0 28 28"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M5 22V8l9-3 9 3v14" stroke="#a78bfa"></path><path
                d="M5 22h18M11 22v-7M17 22v-7"
                stroke="#a78bfa"></path><circle cx="14" cy="11" r="1.5" fill="#a78bfa"
              ></circle></svg
            >
            <h3>Self-hosted, BSD-3</h3>
            <p>
              Your network, your data, your binaries. Forked from NetBird at
              v0.52.2 — fully open, fork-friendly, embeddable in BSD/MIT
              downstreams.
            </p>
          </div>
          <div class="feature reveal">
            <svg
              width="28"
              height="28"
              viewBox="0 0 28 28"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="8" cy="14" r="4" stroke="#a78bfa"></circle><circle
                cx="20"
                cy="14"
                r="4"
                stroke="#a78bfa"></circle><path d="M12 14h4" stroke="#a78bfa"
              ></path><path
                d="M8 7v3M20 7v3M8 18v3M20 18v3"
                stroke="#a78bfa"></path></svg
            >
            <h3>Real high availability</h3>
            <p>
              Active-active management with embedded NATS coordinator. Sub-
              second failover, no external Redis, no Postgres dance.
              Data plane is pure WireGuard — survives coordinator outages.
            </p>
          </div>
          <div class="feature reveal">
            <svg
              width="28"
              height="28"
              viewBox="0 0 28 28"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14 4l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V7l8-3z"
                stroke="#a78bfa"></path><path
                d="M10 13l3 3 5-5"
                stroke="#a78bfa"></path></svg
            >
            <h3>OIDC SSO via embedded Dex</h3>
            <p>
              Keycloak, Auth0, Google, Microsoft Entra, Okta, Authentik,
              Zitadel, GitHub — federate any OIDC IdP. Single-ingress, single
              cert, same-origin cookies.
            </p>
          </div>
          <div class="feature reveal">
            <svg
              width="28"
              height="28"
              viewBox="0 0 28 28"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14 4l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V7l8-3z"
                stroke="#a78bfa"></path><path
                d="M10 13l3 3 5-5"
                stroke="#a78bfa"></path></svg
            >
            <h3>MDM / EDR posture validation</h3>
            <p>
              Microsoft Intune, SentinelOne, Huntress, CrowdStrike Falcon —
              admission gated on real-time compliance status from your fleet
              tooling. Plus 5 native checks (OS / kernel version, geo, peer
              network range, required processes, client version).
            </p>
          </div>
          <div class="feature reveal">
            <svg
              width="28"
              height="28"
              viewBox="0 0 28 28"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M14 4v8M14 16v8M4 14h8M16 14h8" stroke="#a78bfa"
              ></path><circle cx="14" cy="14" r="3" stroke="#a78bfa"
              ></circle></svg
            >
            <h3>Tag-based ACL policies</h3>
            <p>
              Group by tag, allow / deny by group. Compiles to WireGuard
              allowed-IPs at the peer. Diff before apply, version in git,
              roll back in seconds.
            </p>
          </div>
          <div class="feature reveal">
            <svg
              width="28"
              height="28"
              viewBox="0 0 28 28"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M6 4h12l4 4v16H6z" stroke="#a78bfa"></path><path
                d="M18 4v4h4M10 13h8M10 17h8M10 9h4"
                stroke="#a78bfa"></path></svg
            >
            <h3>Audit-grade event log</h3>
            <p>
              Every admission, policy change, peer connect / disconnect tied
              to a verified identity. JSON output on every CLI; ship to your
              SIEM via syslog or push to S3.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         5. CLI SHOWCASE — terminal mock with 3 tabs
         ============================================================ -->
    <section class="section dark" id="cli">
      <div class="bg-grid-dark"></div>
      <div class="section-inner cli-inner">
        <div class="cli-copy">
          <span class="eyebrow on-dark"
            ><span class="dot"></span>The CLI</span
          >
          <h2 class="display on-dark">
            Boring on purpose.<br /><em>Predictable</em> by design.
          </h2>
          <p class="lead on-dark">
            No SaaS console required. Every action is a single command,
            deterministic, idempotent, and produces an audit event you can
            replay.
          </p>
          <ul class="cli-points">
            <li>
              <span class="bullet"></span>Signed packages on every distro,
              GHCR images for K8s
            </li>
            <li>
              <span class="bullet"></span>Works inside k8s, systemd, Nomad,
              or bare metal via Ansible
            </li>
            <li>
              <span class="bullet"></span>JSON output on every command — pipe
              to anything
            </li>
          </ul>
        </div>
        <div class="terminal">
          <div class="term-chrome">
            <span class="dot r"></span><span class="dot y"></span><span
              class="dot g"></span>
            <span class="term-title">openzro · zsh</span>
          </div>
          <div class="term-tabs" id="term-tabs">
            <button class="term-tab active" data-tab="install">Install</button>
            <button class="term-tab" data-tab="join">Join</button>
            <button class="term-tab" data-tab="audit">Audit</button>
          </div>

          <pre class="term-body" data-pane="install">
<span class="term-line"><span class="prompt">$</span><span class="cmd">curl -fsSL https://pkg.openzro.io/install.sh | sh</span></span>
<span class="term-line"><span class="comment">→ detected ubuntu 22.04 · adding pkg.openzro.io apt repo</span></span>
<span class="term-line"><span class="comment">→ installing openzro 0.53.1-alpha.13 · BSD-3</span></span>
<span class="term-line"><span class="comment">→ creating systemd unit · openzro.service</span></span>
<span class="term-line"><span class="prompt">$</span><span class="cmd">openzro version</span></span>
<span class="term-line"><span class="out">openzro v0.53.1-alpha.13 (BSD-3) · WireGuard 1.0.20210914</span></span>
          </pre>
          <pre class="term-body" data-pane="join" hidden>
<span class="term-line"><span class="prompt">$</span><span class="cmd">sudo openzro up --management-url https://openzro.example.com</span></span>
<span class="term-line"><span class="comment">→ generating WireGuard key · ed25519</span></span>
<span class="term-line"><span class="comment">→ presenting OIDC login · browser opened</span></span>
<span class="term-line"><span class="warn">⏸ awaiting login · provider: keycloak</span></span>
<span class="term-line"><span class="ok">✓ joined · scope: prod · routes: 10.42.0.0/16, 10.50.0.0/24</span></span>
<span class="term-line"><span class="prompt">$</span><span class="cmd">_<span class="cursor"></span></span></span>
          </pre>
          <pre class="term-body" data-pane="audit" hidden>
<span class="term-line"><span class="prompt">$</span><span class="cmd">openzro status -d</span></span>
<span class="term-line"><span class="out">Management: Connected</span></span>
<span class="term-line"><span class="out">Signal:     Connected</span></span>
<span class="term-line"><span class="out">Relays:     OK · 2 reachable</span></span>
<span class="term-line"><span class="prompt">$</span><span class="cmd">journalctl -u openzro -f</span></span>
<span class="term-line"><span class="comment">2026-04-30T05:14:02 · admission · sre@example.com · admitted</span></span>
<span class="term-line"><span class="comment">2026-04-30T05:14:08 · peer-connect · edge-sa · 12ms</span></span>
<span class="term-line"><span class="comment">2026-04-30T13:02:41 · route-add · 10.42.0.0/16</span></span>
          </pre>
        </div>
      </div>
    </section>

    <!-- ============================================================
         6. USE CASES — light section, 4 industry/topology cards
         ============================================================ -->
    <section class="section light" id="use-cases">
      <div class="bg-grid-light"></div>
      <div class="section-inner">
        <header class="sec-head">
          <span class="eyebrow on-light"
            ><span class="dot"></span>Use cases</span
          >
          <h2 class="display">
            What teams are running it for.
          </h2>
        </header>
        <div class="cases">
          <div class="case reveal">
            <div class="case-head">
              <span class="case-tag">multi-cloud</span>
            </div>
            <h3>Mesh across AWS, GCP and on-prem</h3>
            <p>
              One overlay between every region, every account, every cloud.
              Replace VPC peering and Transit Gateway with a peer-to-peer
              fabric that your platform team controls end to end.
            </p>
            <a class="case-link" href="https://docs.openzro.io">Read the docs →</a>
          </div>
          <div class="case reveal">
            <div class="case-head">
              <span class="case-tag">platform</span>
            </div>
            <h3>Multi-cluster Kubernetes</h3>
            <p>
              Routable, encrypted plane between clusters with per-namespace
              ACLs. Replace bespoke peering with one abstraction. Helm chart
              ships everything you need.
            </p>
            <a
              class="case-link"
              href="https://github.com/openzro/helms"
              >Helm chart →</a
            >
          </div>
          <div class="case reveal">
            <div class="case-head">
              <span class="case-tag">on-prem</span>
            </div>
            <h3>Air-gap-friendly self-host</h3>
            <p>
              No telemetry, no SaaS, no phone-home. Mirror the registry once,
              run it forever in your enclave. Bare-metal Ansible playbook for
              hosts without Kubernetes.
            </p>
            <a
              class="case-link"
              href="https://github.com/openzro/openzro-ansible"
              >Ansible playbook →</a
            >
          </div>
          <div class="case reveal">
            <div class="case-head">
              <span class="case-tag">replace VPN</span>
            </div>
            <h3>Drop-in replacement for legacy VPN</h3>
            <p>
              Per-peer identity, per-flow audit, modern OIDC login. Keep your
              IdP, swap the tunnel. Native clients on macOS, Windows, Linux,
              Android and iOS.
            </p>
            <a
              class="case-link"
              href="https://github.com/openzro/openzro/blob/main/docs/adr/0001-openzro-foundation.md"
              >Why we forked →</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         7. COMPARE — deeper dark, table
         ============================================================ -->
    <section class="section deep" id="compare">
      <div class="bg-grid-dark"></div>
      <div class="section-inner">
        <header class="sec-head">
          <span class="eyebrow on-dark"
            ><span class="dot"></span>Comparison</span
          >
          <h2 class="display on-dark">
            Versus the rack of compromises<br />you've been stacking.
          </h2>
        </header>
        <div class="compare-table">
          <div class="ct-row ct-head">
            <div class="ct-feat">Capability</div>
            <div class="ct-col oz">
              <img src="/brand/openzro-icon.svg" width="20" height="20" alt="" />
              <span>openZro</span>
            </div>
            <div class="ct-col">Legacy VPN</div>
            <div class="ct-col">SaaS SD-WAN</div>
          </div>

          <div class="ct-row">
            <div class="ct-feat">Self-hosted, no SaaS dependency</div>
            <div class="ct-col oz"><span class="cell yes">✓</span></div>
            <div class="ct-col">
              <span class="cell partial">partial</span>
            </div>
            <div class="ct-col"><span class="cell no">—</span></div>
          </div>
          <div class="ct-row">
            <div class="ct-feat">Full WireGuard mesh (peer-to-peer)</div>
            <div class="ct-col oz"><span class="cell yes">✓</span></div>
            <div class="ct-col"><span class="cell no">—</span></div>
            <div class="ct-col">
              <span class="cell partial">partial</span>
            </div>
          </div>
          <div class="ct-row">
            <div class="ct-feat">OIDC SSO with any IdP (Dex-federated)</div>
            <div class="ct-col oz"><span class="cell yes">✓</span></div>
            <div class="ct-col">
              <span class="cell partial">partial</span>
            </div>
            <div class="ct-col"><span class="cell yes">✓</span></div>
