    <!-- ============================================================
         Inline JS — canvas init, tab switcher, scroll reveal,
         marquee duplication, nav blur on scroll
         ============================================================ -->
    <script>
      import { initMeshViz } from "../scripts/mesh-viz.js";

      const ready = () =>
        document.readyState === "loading"
          ? document.addEventListener("DOMContentLoaded", boot)
          : boot();

      function boot() {
        // 1. Mesh canvas
        const canvas = document.getElementById("mesh-canvas");
        if (canvas) initMeshViz(canvas);

        // 2. Marquee — duplicate items so the loop is seamless
        const track = document.getElementById("marquee-track");
        if (track) {
          track.append(...Array.from(track.children).map((n) => n.cloneNode(true)));
        }

        // 3. CLI terminal tabs
        const tabs = document.getElementById("term-tabs");
        if (tabs) {
          tabs.addEventListener("click", (e) => {
            const btn = e.target.closest(".term-tab");
            if (!btn) return;
            const target = btn.dataset.tab;
            tabs.querySelectorAll(".term-tab").forEach((b) =>
              b.classList.toggle("active", b === btn),
            );
            document.querySelectorAll(".term-body").forEach((p) => {
              p.hidden = p.dataset.pane !== target;
            });
          });
        }

        // 4. Sticky nav — scrolled state
        const nav = document.getElementById("nav");
        if (nav) {
          const onScroll = () =>
            nav.classList.toggle("scrolled", window.scrollY > 12);
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }

        // 5. Scroll reveal
        document
          .querySelectorAll(".hero .reveal")
          .forEach((el) => el.classList.add("in"));

        document
          .querySelectorAll(".step, .feature, .case, .ct-row:not(.ct-head)")
          .forEach((el) => el.classList.add("reveal"));

        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
        );
        document.querySelectorAll(".reveal:not(.in)").forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight && r.bottom > 0) {
            el.classList.add("in");
          } else {
            io.observe(el);
          }
        });
      }

      ready();
    </script>
